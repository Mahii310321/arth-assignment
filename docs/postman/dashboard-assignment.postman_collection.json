        {
          "name": "GET /api/transactions?page=1&limit=10",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('transactions returns 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('transactions has pagination metadata', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.have.property('data');",
                  "  pm.expect(body).to.have.property('pagination');",
                  "  pm.expect(body.pagination).to.include.keys(['page', 'limit', 'total', 'totalPages']);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
