{
  "info": {
    "name": "Dashboard Assignment API",
    "description": "API testing collection for auth, dashboard, pagination, CSV export, logout, and SSE stream.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "testEmail",
      "value": "postman.user@example.com"
    },
    {
      "key": "testPassword",
      "value": "Password@123"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "GET /health",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('health returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('service is ok', function () { pm.expect(pm.response.json().status).to.eql('ok'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /api/auth/register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Postman User\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\",\n  \"profileImageUrl\": \"https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?w=200&h=200&fit=crop&crop=faces\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('register returns created or already exists', function () { pm.expect([201, 409]).to.include(pm.response.code); });",
                  "if (pm.response.code === 201) { pm.collectionVariables.set('token', pm.response.json().token); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login seeded Samantha",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"samantha@email.com\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('login returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('token exists', function () { pm.expect(pm.response.json().token).to.be.a('string'); });",
                  "pm.collectionVariables.set('token', pm.response.json().token);"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "POST /api/auth/login invalid credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"samantha@email.com\",\n  \"password\": \"wrong-password\"\n}"
            },
            "url": "{{baseUrl}}/api/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('invalid login returns 401', function () { pm.response.to.have.status(401); });",
                  "pm.test('message is clear', function () { pm.expect(pm.response.json().message).to.eql('Invalid email or password.'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /api/auth/me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/auth/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('me returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('user has email', function () { pm.expect(pm.response.json().user.email).to.be.a('string'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "GET /api/dashboard",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/dashboard"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('dashboard returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('dashboard has expected fields', function () { const body = pm.response.json(); pm.expect(body).to.include.keys(['user', 'recentTransactions', 'spendStatistics', 'chartData', 'cardsData', 'transactionsPagination']); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /api/transactions?page=1&limit=10",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/transactions?page=1&limit=10"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('transactions returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('pagination exists', function () { pm.expect(pm.response.json().pagination).to.include.keys(['page', 'limit', 'total', 'totalPages']); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /api/transactions?page=2&limit=10",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/transactions?page=2&limit=10"
          }
        },
        {
          "name": "GET /api/export/transactions.csv",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/export/transactions.csv"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('csv export returns 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('csv has headers', function () { pm.expect(pm.response.text()).to.include('id,title,category,amount'); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "GET /api/dashboard/stream?token={{token}}",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/dashboard/stream?token={{token}}"
          },
          "description": "SSE endpoint. Postman will keep this request open and display streamed dashboard events."
        }
      ]
    },
    {
      "name": "Logout",
      "item": [
        {
          "name": "POST /api/auth/logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{baseUrl}}/api/auth/logout"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('logout returns 200', function () { pm.response.to.have.status(200); });"
                ],
                "type": "text/javascript"
              }
            }
          ]
        }
      ]
    }
  ]
}
