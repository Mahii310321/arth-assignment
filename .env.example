# Optional Docker Compose overrides.
# Docker works without this file because docker-compose.yml has safe local defaults.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=dashboard_assignment

CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
VITE_API_BASE_URL=http://localhost:4000
DOCKER_DATABASE_URL=postgresql://postgres:postgres@postgres:5432/dashboard_assignment?schema=public
JWT_SECRET=dashboard-assignment-local-jwt-secret-change-for-production
JWT_EXPIRES_IN=1d
